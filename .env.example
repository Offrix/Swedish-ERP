NODE_ENV=development
NODE_VERSION=24.14.0
PNPM_VERSION=10.12.4
PYTHON_VERSION=3.14.3
POSTGRES_IMAGE=postgres:18.0
VALKEY_IMAGE=valkey/valkey:8.0.0-bookworm
POSTGRES_DB=swedish_erp
POSTGRES_USER=swedish_erp
POSTGRES_PASSWORD=swedish_erp
POSTGRES_PORT=55432
VALKEY_PORT=56379
MINIO_PORT=59000
MAILPIT_SMTP_PORT=51025
MAILPIT_UI_PORT=58025
API_PORT=4000
DESKTOP_WEB_PORT=4001
FIELD_MOBILE_PORT=4002
WORKER_INTERVAL_MS=1000
PHASE2_DOCUMENT_ARCHIVE_ENABLED=true
PHASE2_COMPANY_INBOX_ENABLED=true
PHASE2_OCR_REVIEW_ENABLED=true
PHASE3_LEDGER_ENABLED=true
PHASE4_VAT_ENABLED=true
PHASE5_AR_ENABLED=true
PHASE6_AP_ENABLED=true
PHASE7_HR_ENABLED=true
PHASE7_TIME_ENABLED=true
PHASE7_ABSENCE_ENABLED=true
PHASE8_PAYROLL_ENABLED=true
PHASE9_BENEFITS_ENABLED=true
PHASE9_TRAVEL_ENABLED=true
PHASE9_PENSION_ENABLED=true
PHASE10_PROJECTS_ENABLED=true
PHASE10_FIELD_ENABLED=true
PHASE10_BUILD_ENABLED=true
PHASE13_PUBLIC_API_ENABLED=true
PHASE13_PARTNER_ENABLED=true
PHASE13_AUTOMATION_ENABLED=true
PHASE14_SECURITY_ENABLED=true
PHASE14_RESILIENCE_ENABLED=true
PHASE14_MIGRATION_ENABLED=true

# Secret runtime defaults to software-backed keys for local development only.
# Protected or production-like modes must switch to aws_kms and populate wrapped root material.
ERP_SECRET_RUNTIME_PROVIDER=software_kms
# ERP_AWS_KMS_REGION=eu-north-1
# ERP_AWS_KMS_MODE_ROOT_KEY_ID=alias/swedish-erp/mode-root-key
# ERP_AWS_KMS_MODE_ROOT_WRAPPED_B64=
# ERP_AWS_KMS_SERVICE_KEK_KEY_ID=alias/swedish-erp/service-kek
# ERP_AWS_KMS_SERVICE_KEK_WRAPPED_B64=
# ERP_AWS_KMS_BLIND_INDEX_KEY_ID=alias/swedish-erp/blind-index-key
# ERP_AWS_KMS_BLIND_INDEX_WRAPPED_B64=
